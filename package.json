{
  "name": "online-code-judge-root",
  "version": "1.0.0",
  "description": "Monorepo root for Online Code Judge Platform",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:server": "npm run dev --prefix backend",
    "dev:client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --prefix frontend",
    "build:server": "npm run build --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
